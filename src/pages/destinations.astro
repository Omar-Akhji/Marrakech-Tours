---
import SubpageLayout from "../layouts/SubpageLayout.astro";
import PageHero from "../components/PageHero.astro";
import { destinations } from "../data/destinationsData";
---

<SubpageLayout title="Morocco Destinations">
  <PageHero
    description="From the electric markets of Marrakech to the quiet expanse of the Sahara and the cool sea breezes of the coast."
    title="Explore Morocco"
  />

  <!-- Destinations Grid -->
  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-12">
    <div
      class="grid grid-cols-1 gap-6 md:grid-cols-3"
      data-animate="stagger-cards"
    >
      {
        destinations.map((destination, index) => (
          <article
            class:list={[
              `group relative flex min-h-112.5 flex-col justify-end overflow-hidden rounded-2xl border border-border-subtle bg-surface-card p-6 transition-all duration-500 hover:border-border-gold hover:shadow-xl hover:shadow-brand-gold/5 md:p-8`,
              { "md:col-span-2": index === 0 || index === 4 },
            ]}
          >
            {/* Background Image */}
            <div class="absolute inset-0 z-0 overflow-hidden">
              <div class="h-full w-full overflow-hidden transition-transform duration-700 group-hover:scale-105">
                <img
                  alt={destination.title}
                  class="h-full w-full scale-120 object-cover brightness-[0.4] filter"
                  data-animate="parallax"
                  src={destination.image}
                />
              </div>
              <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent" />
            </div>

            {/* Content overlay */}
            <div class="relative z-10">
              <span class="mb-2 block text-xs font-semibold tracking-widest text-brand-gold uppercase">
                {destination.region}
              </span>
              <h3 class="mb-3 font-display text-3xl font-bold text-white text-shadow-black/8 text-shadow-xs">
                {destination.title}
              </h3>
              <p class="mb-6 max-w-2xl font-body text-sm leading-relaxed text-text-secondary">
                {destination.desc}
              </p>

              <div class="flex flex-wrap gap-2">
                {destination.highlights.map((item) => (
                  <span class="rounded-full border border-border-subtle bg-white/10 px-3 py-1 text-[11px] font-medium text-white/80">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SubpageLayout>
