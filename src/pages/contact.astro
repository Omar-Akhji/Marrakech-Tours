---
/* eslint-disable astro/no-unsafe-inline-scripts */
import SubpageLayout from "../layouts/SubpageLayout.astro";
import { MapPin, Phone, Mail } from "lucide-astro";
---

<SubpageLayout title="Contact Us">
  <!-- Hero Section -->
  <section class="relative py-20 px-6 text-center max-w-5xl mx-auto">
    <h1
      class="text-5xl md:text-6xl font-[Oswald] font-bold uppercase tracking-wider text-transparent bg-clip-text bg-linear-to-r from-[#ecad29] to-[#ff7a00] text-shadow-black/10 text-shadow-sm"
      data-animate="fade-up"
    >
      Start Your Journey
    </h1>
    <p
      class="mt-4 text-white/70 max-w-2xl mx-auto text-base leading-relaxed font-[Outfit]"
      data-animate="fade-up"
    >
      Have questions about our custom desert excursions or group itineraries? Reach out to our
      Marrakech specialists.
    </p>
  </section>

  <!-- Contact Grid -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Contact Form -->
      <div
        class="lg:col-span-7 bg-white/5 border border-white/5 rounded-2xl p-8 shadow-xl"
        data-animate="slide-left"
      >
        <h2 class="text-3xl font-[Outfit] font-bold text-white mb-6 text-shadow-black/8 text-shadow-xs">Send a Message</h2>
        <form
          class="space-y-6"
          id="contact-form"
          aria-label="Contact form"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label
                class="block text-xs uppercase tracking-wider text-white/50 mb-2"
                for="name"
                >Full Name</label
              >
              <input
                class="w-full px-4 py-3 rounded-lg border border-white/10 bg-[#1a1a1a]/50 text-white placeholder-white/20 focus:outline-hidden focus:border-[#ecad29]/40 transition-colors"
                id="name"
                placeholder="John Doe"
                required
                type="text"
              />
            </div>
            <div>
              <label
                class="block text-xs uppercase tracking-wider text-white/50 mb-2"
                for="email"
                >Email Address</label
              >
              <input
                class="w-full px-4 py-3 rounded-lg border border-white/10 bg-[#1a1a1a]/50 text-white placeholder-white/20 focus:outline-hidden focus:border-[#ecad29]/40 transition-colors"
                id="email"
                placeholder="john@example.com"
                required
                type="email"
              />
            </div>
          </div>

          <div>
            <label
              class="block text-xs uppercase tracking-wider text-white/50 mb-2"
              for="subject"
              >Subject</label
            >
            <input
              class="w-full px-4 py-3 rounded-lg border border-white/10 bg-[#1a1a1a]/50 text-white placeholder-white/20 focus:outline-hidden focus:border-[#ecad29]/40 transition-colors"
              id="subject"
              placeholder="Inquiry about Sahara Trek"
              required
              type="text"
            />
          </div>

          <div>
            <label
              class="block text-xs uppercase tracking-wider text-white/50 mb-2"
              for="message"
              >Message</label
            >
            <textarea
              class="w-full px-4 py-3 rounded-lg border border-white/10 bg-[#1a1a1a]/50 text-white placeholder-white/20 focus:outline-hidden focus:border-[#ecad29]/40 transition-colors"
              id="message"
              placeholder="Tell us about your travel dates, group size, and preferred destinations..."
              required
              rows="5"
            ></textarea>
          </div>

          <button
            class="px-8 py-3 rounded-lg bg-linear-to-r from-[#ecad29] to-[#ff7a00] hover:from-[#f3b73f] hover:to-[#ff8d23] text-black font-semibold uppercase tracking-wider transition-all shadow-md shadow-[#ecad29]/10 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            id="submit-btn"
            type="submit"
          >
            <span id="submit-text">Submit Inquiry</span>
            <svg
              class="hidden h-5 w-5 animate-spin text-black"
              fill="none"
              id="submit-spinner"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"
              ></circle>
              <path
                class="opacity-75"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                fill="currentColor"
              ></path>
            </svg>
          </button>

          <div
            class="hidden rounded-lg bg-green-500/20 border border-green-500/30 p-4 text-green-200 mt-4"
            id="success-message"
          >
            <p class="font-medium">Message sent successfully!</p>
            <p class="text-sm mt-1">Our concierge will contact you within 24 hours.</p>
          </div>
        </form>
      </div>

      <!-- Contact Info -->
      <div
        class="lg:col-span-5 flex flex-col justify-between gap-8"
        data-animate="slide-right"
      >
        <div class="bg-white/5 border border-white/5 rounded-2xl p-8 shadow-xl space-y-6">
          <h2 class="text-3xl font-[Outfit] font-bold text-white mb-2 text-shadow-black/8 text-shadow-xs">Our Riad Office</h2>
          <p class="text-white/60 text-sm leading-relaxed font-[Inter]">
            Located in the heart of the historic Medina, our team is ready to design your customized
            Moroccan journey.
          </p>

          <div class="space-y-4 pt-4 text-sm">
            <div class="flex items-start gap-4">
              <div class="p-2.5 rounded-lg bg-white/5 border border-white/5 text-[#ecad29]">
                <MapPin class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Address</span>
                <span class="text-white/60"
                  >42 Derb Riad, Zitoune District, Medina, Marrakech 40000, Morocco</span
                >
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="p-2.5 rounded-lg bg-white/5 border border-white/5 text-[#ecad29]">
                <Phone class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Phone Support</span>
                <span class="text-white/60">+212 (0) 524 892 100</span>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="p-2.5 rounded-lg bg-white/5 border border-white/5 text-[#ecad29]">
                <Mail class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Email Address</span>
                <span class="text-white/60">bookings@marrakechexpress.com</span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white/5 border border-white/5 rounded-2xl p-8 shadow-xl">
          <h3
            class="text-lg font-[Outfit] font-semibold text-[#ecad29] uppercase tracking-wide mb-3"
          >
            Custom Excursions
          </h3>
          <p class="text-white/60 text-sm leading-relaxed font-[Inter]">
            Interested in booking a custom itinerary? Tell us your budget, requirements, and travel
            goals and our concierge will construct a tailor-made proposal within 24 hours.
          </p>
        </div>
      </div>
    </div>
  </section>
</SubpageLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const contactForm = document.querySelector("#contact-form") as HTMLFormElement | null;
    const submitBtn = document.querySelector("#submit-btn") as HTMLButtonElement | null;
    const submitText = document.querySelector("#submit-text");
    const submitSpinner = document.querySelector("#submit-spinner");
    const successMessage = document.querySelector("#success-message");

    if (contactForm && submitBtn && submitText && submitSpinner && successMessage) {
      // Pre-fill tour subject if provided in URL params
      const urlParams = new URLSearchParams(globalThis.location.search);
      const tourParam = urlParams.get("tour");
      const subjectInput = document.querySelector("#subject") as HTMLInputElement | null;
      if (tourParam && subjectInput) {
        subjectInput.value = `Inquiry about: ${tourParam}`;
      }

      contactForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Loading state
        submitBtn.disabled = true;
        submitText.textContent = "Sending...";
        submitSpinner.classList.remove("hidden");

        // Simulate network request
        await new Promise((resolve) => setTimeout(resolve, 1200));

        // Success state
        contactForm.reset();
        submitBtn.disabled = false;
        submitText.textContent = "Submit Inquiry";
        submitSpinner.classList.add("hidden");

        successMessage.classList.remove("hidden");

        setTimeout(() => {
          successMessage.classList.add("hidden");
        }, 5000);
      });
    }
  });
</script>
