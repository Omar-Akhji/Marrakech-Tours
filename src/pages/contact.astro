---
import SubpageLayout from "../layouts/SubpageLayout.astro";
import PageHero from "../components/PageHero.astro";
import { MapPin, Phone, Mail } from "lucide-astro";
---

<SubpageLayout title="Contact Us">
  <PageHero
    description="Have questions about our custom desert excursions or group itineraries? Reach out to our Marrakech specialists."
    title="Start Your Journey"
  />

  <!-- Contact Grid -->
  <section class="mx-auto max-w-7xl overflow-hidden px-6 pb-24 md:px-12">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">
      <!-- Contact Form -->
      <div
        class="rounded-2xl border border-border-subtle bg-surface-card p-8 shadow-xl lg:col-span-7"
        data-animate="slide-left"
      >
        <h2
          class="mb-6 font-display text-3xl font-bold text-white text-shadow-black/8 text-shadow-xs"
        >
          Send a Message
        </h2>
        <form
          aria-label="Contact form"
          class="space-y-6"
          id="contact-form"
        >
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
              <label
                class="mb-2 block text-xs uppercase tracking-wider text-text-faint"
                for="name"
                >Full Name</label
              >
              <input
                class="w-full rounded-lg border border-border-muted bg-surface-dark/50 px-4 py-3 text-white placeholder-white/20 transition-colors focus:border-brand-gold/40 focus:outline-hidden"
                id="name"
                placeholder="John Doe"
                required
                type="text"
              />
            </div>
            <div>
              <label
                class="mb-2 block text-xs uppercase tracking-wider text-text-faint"
                for="email"
                >Email Address</label
              >
              <input
                class="w-full rounded-lg border border-border-muted bg-surface-dark/50 px-4 py-3 text-white placeholder-white/20 transition-colors focus:border-brand-gold/40 focus:outline-hidden"
                id="email"
                placeholder="john@example.com"
                required
                type="email"
              />
            </div>
          </div>

          <div>
            <label
              class="mb-2 block text-xs uppercase tracking-wider text-text-faint"
              for="subject"
              >Subject</label
            >
            <input
              class="w-full rounded-lg border border-border-muted bg-surface-dark/50 px-4 py-3 text-white placeholder-white/20 transition-colors focus:border-brand-gold/40 focus:outline-hidden"
              id="subject"
              placeholder="Inquiry about Sahara Trek"
              required
              type="text"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-xs uppercase tracking-wider text-text-faint"
              for="message"
              >Message</label
            >
            <textarea
              class="w-full rounded-lg border border-border-muted bg-surface-dark/50 px-4 py-3 text-white placeholder-white/20 transition-colors focus:border-brand-gold/40 focus:outline-hidden"
              id="message"
              placeholder="Tell us about your travel dates, group size, and preferred destinations..."
              required
              rows="5"
            ></textarea>
          </div>

          <button
            class="flex items-center justify-center gap-2 rounded-lg bg-linear-to-r from-brand-gold to-brand-orange px-8 py-3 font-semibold uppercase tracking-wider text-black shadow-md shadow-brand-gold/10 transition-all hover:from-brand-gold-light hover:to-brand-orange-light disabled:cursor-not-allowed disabled:opacity-50"
            id="submit-btn"
            type="submit"
          >
            <span id="submit-text">Submit Inquiry</span>
            <svg
              class="hidden h-5 w-5 animate-spin text-black"
              fill="none"
              id="submit-spinner"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"
              ></circle>
              <path
                class="opacity-75"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                fill="currentColor"
              ></path>
            </svg>
          </button>

          <div
            class="mt-4 hidden rounded-lg border border-green-500/30 bg-green-500/20 p-4 text-green-200"
            id="success-message"
          >
            <p class="font-medium">Message sent successfully!</p>
            <p class="mt-1 text-sm">Our concierge will contact you within 24 hours.</p>
          </div>
        </form>
      </div>

      <!-- Contact Info -->
      <div
        class="flex flex-col justify-between gap-8 lg:col-span-5"
        data-animate="slide-right"
      >
        <div
          class="space-y-6 rounded-2xl border border-border-subtle bg-surface-card p-8 shadow-xl"
        >
          <h2
            class="mb-2 font-display text-3xl font-bold text-white text-shadow-black/8 text-shadow-xs"
          >
            Our Riad Office
          </h2>
          <p class="font-body text-sm leading-relaxed text-text-muted">
            Located in the heart of the historic Medina, our team is ready to design your customized
            Moroccan journey.
          </p>

          <div class="space-y-4 pt-4 text-sm">
            <div class="flex items-start gap-4">
              <div
                class="rounded-lg border border-border-subtle bg-surface-card p-2.5 text-brand-gold"
              >
                <MapPin class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Address</span>
                <span class="text-text-muted"
                  >42 Derb Riad, Zitoune District, Medina, Marrakech 40000, Morocco</span
                >
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="rounded-lg border border-border-subtle bg-surface-card p-2.5 text-brand-gold"
              >
                <Phone class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Phone Support</span>
                <span class="text-text-muted">+212 (0) 524 892 100</span>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="rounded-lg border border-border-subtle bg-surface-card p-2.5 text-brand-gold"
              >
                <Mail class="h-5 w-5" />
              </div>
              <div>
                <span class="block font-semibold text-white">Email Address</span>
                <span class="text-text-muted">bookings@marrakechexpress.com</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-border-subtle bg-surface-card p-8 shadow-xl">
          <h3
            class="mb-3 font-display text-lg font-semibold uppercase tracking-wide text-brand-gold"
          >
            Custom Excursions
          </h3>
          <p class="font-body text-sm leading-relaxed text-text-muted">
            Interested in booking a custom itinerary? Tell us your budget, requirements, and travel
            goals and our concierge will construct a tailor-made proposal within 24 hours.
          </p>
        </div>
      </div>
    </div>
  </section>
</SubpageLayout>

<script src="../scripts/contact.ts"></script>
