---
import SubpageLayout from "../layouts/SubpageLayout.astro";
import { tours } from "../data/toursData";
import { Star } from "lucide-astro";
---

<SubpageLayout title="Curated Tours">
  <!-- Hero Section -->
  <section class="relative py-20 px-6 text-center max-w-5xl mx-auto">
    <h1
      class="text-5xl md:text-6xl font-[Oswald] font-bold uppercase tracking-wider text-transparent bg-clip-text bg-linear-to-r from-[#ecad29] to-[#ff7a00] text-shadow-black/10 text-shadow-sm"
      data-animate="fade-up"
    >
      Boutique Marrakech Tours
    </h1>
    <p
      class="mt-4 text-white/70 max-w-2xl mx-auto text-base leading-relaxed font-[Outfit]"
      data-animate="fade-up"
    >
      Handcrafted Moroccan journeys starting from Marrakech. Choose your next adventure.
    </p>
  </section>

  <!-- Package Grid -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-8"
      data-animate="stagger-cards"
    >
      {
        tours.map((tour) => (
          <article class="group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-white/5 bg-white/5 shadow-lg shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-[#ecad29]/30">
            {/* Image Header */}
            <div class="relative h-64 overflow-hidden">
              <div class="h-full w-full overflow-hidden transition-transform duration-500 group-hover:scale-105">
                <a
                  class="block h-full w-full"
                  href={`/tours/${tour.id}`}
                >
                  <img
                    alt={tour.title}
                    class="h-full w-full scale-120 object-cover"
                    data-animate="parallax"
                    src={tour.image}
                  />
                </a>
              </div>
              <div class="absolute inset-0 bg-linear-to-t from-[#1a1a1a] to-transparent" />

              {/* Floating price and duration */}
              <div class="absolute top-4 right-4 rounded-full border border-white/10 bg-black/60 px-3 py-1 text-xs font-semibold text-white backdrop-blur-md">
                {tour.duration}
              </div>

              <div class="absolute bottom-4 left-6">
                <span class="mr-2 rounded-md border border-[#ecad29]/20 bg-[#ecad29]/10 px-2.5 py-1 text-xs font-semibold tracking-wider text-[#ecad29] uppercase">
                  {tour.difficulty}
                </span>
                <span class="inline-flex items-center gap-1 text-xs text-white/80">
                  <Star class="h-3.5 w-3.5 fill-[#ecad29] text-[#ecad29]" />
                  {tour.rating}
                </span>
              </div>
            </div>

            {/* Card Content */}
            <div class="flex grow flex-col justify-between p-6 md:p-8">
              <div>
                <div class="mb-3 flex flex-wrap gap-2">
                  {tour.tags.map((tag) => (
                    <span class="rounded-xs bg-white/5 px-2 py-0.5 text-[10px] tracking-widest text-white/40 uppercase">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="mb-3 font-[Outfit] text-2xl font-bold text-white transition-colors group-hover:text-[#ecad29] text-shadow-black/8 text-shadow-xs">
                  <a
                    class="decoration-[#ecad29] decoration-2 underline-offset-4 hover:underline"
                    href={`/tours/${tour.id}`}
                  >
                    {tour.title}
                  </a>
                </h3>
                <p class="mb-6 font-[Inter] text-sm leading-relaxed text-white/60">{tour.desc}</p>
              </div>

              {/* Booking Info */}
              <div class="flex items-center justify-between border-t border-white/5 pt-6">
                <div>
                  <span class="block text-xs tracking-wider text-white/40 uppercase">
                    Starting From
                  </span>
                  <span class="font-[Oswald] text-3xl font-bold text-[#ecad29]">{tour.price}</span>
                </div>
                <a
                  class="rounded-lg border border-white/10 bg-white/5 px-6 py-2.5 text-xs font-semibold tracking-wider text-white uppercase shadow-md transition-all hover:border-transparent hover:bg-linear-to-r hover:from-[#ecad29] hover:to-[#ff7a00] hover:text-black"
                  href={`/tours/${tour.id}`}
                >
                  View Details
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SubpageLayout>
