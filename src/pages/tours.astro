---
import SubpageLayout from "../layouts/SubpageLayout.astro";
import PageHero from "../components/PageHero.astro";
import { tours } from "../data/toursData";
import { Star } from "lucide-astro";
---

<SubpageLayout title="Curated Tours">
  <PageHero
    description="Handcrafted Moroccan journeys starting from Marrakech. Choose your next adventure."
    title="Boutique Marrakech Tours"
  />

  <!-- Package Grid -->
  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-12">
    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2"
      data-animate="stagger-cards"
    >
      {
        tours.map((tour) => (
          <article class="group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-border-subtle bg-surface-card shadow-lg shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-border-gold">
            {/* Image Header */}
            <div class="relative h-64 overflow-hidden">
              <div class="h-full w-full overflow-hidden transition-transform duration-500 group-hover:scale-105">
                <a
                  class="block h-full w-full"
                  href={`/tours/${tour.id}`}
                >
                  <img
                    alt={tour.title}
                    class="h-full w-full scale-120 object-cover"
                    data-animate="parallax"
                    src={tour.image}
                  />
                </a>
              </div>
              <div class="absolute inset-0 bg-linear-to-t from-surface-dark to-transparent" />

              {/* Floating price and duration */}
              <div class="absolute top-4 right-4 rounded-full border border-border-muted bg-black/60 px-3 py-1 text-xs font-semibold text-white backdrop-blur-md">
                {tour.duration}
              </div>

              <div class="absolute bottom-4 left-6">
                <span class="mr-2 rounded-md border border-brand-gold/20 bg-brand-gold/10 px-2.5 py-1 text-xs font-semibold tracking-wider text-brand-gold uppercase">
                  {tour.difficulty}
                </span>
                <span class="inline-flex items-center gap-1 text-xs text-white/80">
                  <Star class="h-3.5 w-3.5 fill-brand-gold text-brand-gold" />
                  {tour.rating}
                </span>
              </div>
            </div>

            {/* Card Content */}
            <div class="flex grow flex-col justify-between p-6 md:p-8">
              <div>
                <div class="mb-3 flex flex-wrap gap-2">
                  {tour.tags.map((tag) => (
                    <span class="rounded-xs bg-surface-card px-2 py-0.5 text-[10px] tracking-widest text-text-faint uppercase">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="mb-3 font-display text-2xl font-bold text-white transition-colors text-shadow-black/8 text-shadow-xs group-hover:text-brand-gold">
                  <a
                    class="decoration-brand-gold decoration-2 underline-offset-4 hover:underline"
                    href={`/tours/${tour.id}`}
                  >
                    {tour.title}
                  </a>
                </h3>
                <p class="mb-6 font-body text-sm leading-relaxed text-text-muted">{tour.desc}</p>
              </div>

              {/* Booking Info */}
              <div class="flex items-center justify-between border-t border-border-subtle pt-6">
                <div>
                  <span class="block text-xs tracking-wider text-text-faint uppercase">
                    Starting From
                  </span>
                  <span class="font-heading text-3xl font-bold text-brand-gold">{tour.price}</span>
                </div>
                <a
                  class="rounded-lg border border-border-muted bg-surface-card px-6 py-2.5 text-xs font-semibold tracking-wider text-white uppercase shadow-md transition-all hover:border-transparent hover:bg-linear-to-r hover:from-brand-gold hover:to-brand-orange hover:text-black"
                  href={`/tours/${tour.id}`}
                >
                  View Details
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SubpageLayout>
