---
/* eslint-disable astro/no-set-html-directive */
import SubpageLayout from "../../layouts/SubpageLayout.astro";
import { posts } from "../../data/blogData";

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const relatedPosts = posts.filter((p) => p.slug !== post.slug).slice(0, 2);
---

<SubpageLayout title={post.title}>
  <!-- Hero Image -->
  <section class="relative h-[55vh] min-h-87.5 overflow-hidden">
    <div class="absolute inset-0">
      <img
        alt={post.title}
        class="h-full w-full scale-105 object-cover"
        data-animate="parallax"
        src={post.image}
      />
    </div>
    <div
      class="absolute inset-0 bg-linear-to-b from-surface-dark/40 via-surface-dark/20 to-surface-dark"
    >
    </div>
    <div class="absolute inset-0 bg-linear-to-r from-surface-dark/60 to-transparent"></div>

    <!-- Floating Back Button -->
    <div class="absolute top-0 right-0 left-0 px-6 md:px-12">
      <div class="mx-auto max-w-4xl">
        <a
          class="mt-14 flex w-fit items-center gap-2 rounded-full border border-border-muted bg-surface-dark/60 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-white/80 backdrop-blur-md transition-all hover:border-brand-gold/40 hover:text-brand-gold"
          href="/blog"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            ></path>
          </svg>
          All Posts
        </a>
      </div>
    </div>

    <!-- Hero Content Overlay -->
    <div class="absolute bottom-0 right-0 left-0 px-6 pb-10 md:px-12">
      <div class="mx-auto max-w-4xl">
        <span
          class="inline-block rounded-xs bg-brand-gold px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-black shadow-lg"
        >
          {post.category}
        </span>
        <h1
          class="mt-4 font-heading text-4xl font-bold uppercase leading-[0.95] tracking-wide text-white text-shadow-black/10 text-shadow-sm md:text-6xl"
          data-animate="fade-up"
        >
          {post.title}
        </h1>
      </div>
    </div>
  </section>

  <!-- Article Meta Bar -->
  <section class="relative z-10 mx-auto -mt-1 max-w-4xl px-6 md:px-12">
    <div
      class="flex flex-wrap items-center justify-between gap-4 border-b border-border-muted py-5"
      data-animate="fade-up"
    >
      <div class="flex items-center gap-3">
        <div
          class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-gold/15 font-heading text-sm font-bold text-brand-gold"
        >
          {
            post.author
              .split(" ")
              .map((n) => n[0])
              .join("")
          }
        </div>
        <div>
          <p class="font-display text-sm font-semibold text-white">{post.author}</p>
          <p class="text-xs text-text-faint">{post.date}</p>
        </div>
      </div>
      <div class="flex items-center gap-4 text-xs text-text-faint">
        <span class="flex items-center gap-1.5">
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            ></path></svg
          >
          {post.readTime}
        </span>
        <span class="h-1 w-1 rounded-full bg-white/20"></span>
        <span>Article</span>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <article
    class="mx-auto max-w-4xl px-6 py-12 md:px-12 md:py-16"
    data-animate="fade-up"
  >
    <div
      class="blog-content"
      set:html={post.content}
    />
  </article>

  <!-- Divider -->
  <div class="mx-auto max-w-4xl px-6 md:px-12">
    <div class="flex items-center gap-4">
      <div class="h-px flex-1 bg-border-muted"></div>
      <div class="h-2 w-2 rotate-45 border border-brand-gold/40 bg-brand-gold/20"></div>
      <div class="h-px flex-1 bg-border-muted"></div>
    </div>
  </div>

  <!-- Related Posts -->
  <section class="mx-auto max-w-4xl px-6 py-16 md:px-12">
    <h2 class="mb-8 font-heading text-xs font-bold uppercase tracking-[0.2em] text-brand-gold">
      Continue Reading
    </h2>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        relatedPosts.map((relatedPost) => (
          <a
            class="group relative block overflow-hidden rounded-xl border border-border-subtle bg-white/3 transition-all duration-300 hover:border-brand-gold/20 hover:bg-surface-card-hover"
            href={`/blog/${relatedPost.slug}`}
          >
            <div class="relative h-48 overflow-hidden">
              <img
                alt={relatedPost.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                src={relatedPost.image}
              />
              <div class="absolute inset-0 bg-linear-to-t from-surface-dark via-surface-dark/40 to-transparent" />
              <span class="absolute top-3 left-3 rounded-xs bg-brand-gold px-2 py-0.5 text-[9px] font-bold tracking-widest text-black uppercase">
                {relatedPost.category}
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-display text-lg leading-snug font-bold text-white transition-colors text-shadow-black/8 text-shadow-xs group-hover:text-brand-gold">
                {relatedPost.title}
              </h3>
              <span class="mt-3 inline-flex items-center gap-1.5 text-[11px] font-semibold tracking-wider text-brand-gold uppercase">
                Read Post
                <svg
                  class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</SubpageLayout>
