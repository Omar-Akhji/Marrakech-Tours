---
import SubpageLayout from "../../layouts/SubpageLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { posts } from "../../data/blogData";
import { Calendar, Clock, ArrowRight } from "lucide-astro";
---

<SubpageLayout title="Travel Blog">
  <PageHero
    description="Insider tips, destination highlights, and cultural chronicles straight from the riads and dunes of Morocco."
    title="Travel Stories & Guides"
  />

  <!-- Blog Bento Grid -->
  <section class="mx-auto max-w-7xl px-6 pb-24 md:px-12">
    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-12"
      data-animate="stagger-cards"
    >
      {
        posts.map((post, index) => {
          const colSpanClass =
            index === 0 ? "md:col-span-12 lg:flex-row" : "md:col-span-6 flex-col";
          return (
            <div
              class:list={[
                "group flex",
                colSpanClass,
                "overflow-hidden rounded-2xl border border-border-subtle bg-surface-card transition-all duration-300 hover:-translate-y-1 hover:border-border-gold",
              ]}
            >
              {/* Image Area */}
              <div
                class:list={[
                  "relative",
                  "overflow-hidden",
                  { "min-h-75 md:w-1/2": index === 0, "h-60 w-full": index !== 0 },
                ]}
              >
                <div class="h-full w-full overflow-hidden transition-transform duration-500 group-hover:scale-103">
                  <img
                    alt={post.title}
                    class="h-full w-full scale-120 object-cover"
                    data-animate="parallax"
                    src={post.image}
                  />
                </div>
                <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
                <span class="absolute top-4 left-4 rounded-xs bg-brand-gold px-2.5 py-1 text-[10px] font-semibold tracking-wider text-black uppercase shadow-md">
                  {post.category}
                </span>
              </div>

              {/* Content Area */}
              <div
                class:list={[
                  `flex flex-col justify-between p-6 md:p-8`,
                  { "md:w-1/2": index === 0, "w-full": index !== 0 },
                ]}
              >
                <div>
                  <div class="mb-3 flex items-center gap-4 text-xs text-text-faint">
                    <span class="flex items-center gap-1.5">
                      <Calendar class="h-3.5 w-3.5" />
                      {post.date}
                    </span>
                    <span>•</span>
                    <span class="flex items-center gap-1.5">
                      <Clock class="h-3.5 w-3.5" />
                      {post.readTime}
                    </span>
                  </div>
                  <h2 class="mb-3 font-display text-2xl leading-tight font-bold text-white transition-colors text-shadow-black/8 text-shadow-xs group-hover:text-brand-gold">
                    {post.title}
                  </h2>
                  <p class="mb-6 font-body text-sm leading-relaxed text-text-muted">
                    {post.excerpt}
                  </p>
                </div>

                <div class="flex items-center justify-between border-t border-border-subtle pt-4">
                  <span class="text-xs text-text-faint">By {post.author}</span>
                  <a
                    class="flex items-center gap-1.5 text-xs font-semibold tracking-wider text-brand-gold uppercase transition-colors hover:text-white"
                    href={`/blog/${post.slug}`}
                  >
                    Read Post
                    <ArrowRight class="h-4 w-4 transform transition-transform group-hover:translate-x-1" />
                  </a>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>
</SubpageLayout>
