---
import type { CardItem } from "../data/sliderData";

export interface Props {
  data: CardItem[];
}

const { data } = Astro.props;
---

<div
  class="pagination absolute top-0 left-0 inline-flex items-center gap-4"
  id="pagination"
>
  <div class="progress-sub-container z-60 flex h-12.5 w-24 items-center sm:w-48 md:w-80 lg:w-100">
    <div class="progress-sub-background h-0.75 w-full bg-white/20">
      <div class="progress-sub-foreground h-0.75 bg-brand-gold"></div>
    </div>
  </div>
  <div
    class="slide-numbers relative z-60 h-12.5 w-12.5 overflow-hidden"
    id="slide-numbers"
  >
    {
      data.map((_, index) => (
        <div
          class="item absolute top-0 left-0 grid h-12.5 w-12.5 place-items-center text-xl font-bold text-white sm:text-2xl md:text-[32px]"
          id={`slide-item-${index}`}
        >
          {index + 1}
        </div>
      ))
    }
  </div>
</div>
