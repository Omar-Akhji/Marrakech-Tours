---
import { navLinks } from "../data/navigation";

export interface Props {
  currentPath?: string;
}

const pathname = new URL(Astro.request.url).pathname;
const currentPath = Astro.props.currentPath ?? pathname.replace(/\/$/, "");
---

<nav
  aria-label="Primary Navigation"
  class="relative inline-flex items-center gap-3 overflow-hidden rounded-full border border-border-muted bg-surface-card p-2 shadow-sm backdrop-blur-md"
>
  <!-- Sliding Indicator -->
  <div
    class="nav-indicator absolute inset-y-2 left-0 z-0 rounded-full bg-linear-to-br from-brand-gold to-brand-orange opacity-0 shadow-lg shadow-brand-gold/20"
    style="pointer-events: none;"
  >
  </div>
  <ul class="nav-links m-0 inline-flex list-none items-center gap-3 p-0">
    {
      navLinks.map((link) => {
        const isActive = currentPath === (link.href === "/" ? "" : link.href);
        return (
          <li>
            <a
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "nav-item relative z-10 block rounded-full px-6 py-2.5 text-sm font-display font-semibold uppercase no-underline transition-colors duration-200",
                { "text-black": isActive, "text-text-muted": !isActive },
              ]}
              href={link.href}
            >
              {link.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<script src="../scripts/navbar.ts"></script>

<style>
  nav {
    max-width: 90vw;
    overflow-x: auto;
  }

  .nav-links {
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  :global(.nav-item) {
    flex-shrink: 0;
  }
</style>
