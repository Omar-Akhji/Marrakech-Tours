---
export interface Props {
  id: "details-even" | "details-odd";
  place?: string;
  title?: string;
  title2?: string;
  description?: string;
}

const { id, place = "", title = "", title2 = "", description = "" } = Astro.props;
---

<div
  class="details absolute z-20 w-full max-w-full sm:max-w-112.5 lg:max-w-125"
  id={id}
>
  <div class="place-box h-11.5 overflow-hidden">
    <div
      class="text relative pt-4 text-sm sm:text-base md:text-lg lg:text-xl before:absolute before:top-0 before:left-0 before:h-1 before:w-7.5 before:rounded-full before:bg-white before:content-['']"
    >
      {place}
    </div>
  </div>
  <div
    class="title-box-1 mt-0.5 h-[1.15em] overflow-hidden text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-none"
  >
    <div
      class="title-1 font-[Oswald] text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-none"
    >
      {title}
    </div>
  </div>
  <div
    class="title-box-2 mt-0.5 h-[1.15em] overflow-hidden text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-none"
  >
    <div
      class="title-2 font-[Oswald] text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-none"
    >
      {title2}
    </div>
  </div>
  <div
    class="desc font-['Montserrat'] mt-4 w-full text-xs sm:text-sm md:text-base text-white/70 leading-relaxed"
  >
    {description}
  </div>
  <div class="cta mt-6 flex w-full items-center">
    <button
      class="discover h-9 cursor-pointer rounded-full border border-white bg-transparent px-6 py-1 text-xs text-white uppercase"
      >Discover Location</button
    >
  </div>
</div>
