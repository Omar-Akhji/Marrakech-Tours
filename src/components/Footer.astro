---
import { Instagram, Twitter, Youtube } from "lucide-astro";

// eslint-disable-next-line @typescript-eslint/no-empty-object-type
export interface Props {}
---

<footer class="bg-black/40 border-t border-white/5 py-12 mt-16 backdrop-blur-md">
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-3 gap-12 text-sm text-white/60"
  >
    <div class="flex flex-col justify-between">
      <div>
        <h3 class="text-[#ecad29] font-[Oswald] text-2xl font-bold uppercase tracking-wider mb-3">
          Marrakech Express
        </h3>
        <p class="leading-relaxed">
          Embark on boutique journeys and luxury custom desert expeditions from Marrakech to the
          edge of the Sahara. Guided treks, sand dune camping, and rich cultural excursions.
        </p>
      </div>
      <div class="mt-6 flex items-center gap-4">
        <a
          aria-label="Instagram"
          class="hover:text-[#ecad29] transition-colors"
          href="#"
        >
          <Instagram class="h-6 w-6" />
        </a>
        <a
          aria-label="X (Twitter)"
          class="hover:text-[#ecad29] transition-colors"
          href="#"
        >
          <Twitter class="h-5 w-5" />
        </a>
        <a
          aria-label="YouTube"
          class="hover:text-[#ecad29] transition-colors"
          href="#"
        >
          <Youtube class="h-6 w-6" />
        </a>
      </div>
    </div>

    <div class="md:pl-12">
      <h4 class="text-white font-[Outfit] font-semibold text-lg uppercase tracking-wide mb-4">
        Quick Links
      </h4>
      <ul class="space-y-2">
        <li>
          <a
            class="hover:text-[#ecad29] transition-colors"
            href="/"
            >Home</a
          >
        </li>
        <li>
          <a
            class="hover:text-[#ecad29] transition-colors"
            href="/tours"
            >Tours</a
          >
        </li>
        <li>
          <a
            class="hover:text-[#ecad29] transition-colors"
            href="/destinations"
            >Destinations</a
          >
        </li>
        <li>
          <a
            class="hover:text-[#ecad29] transition-colors"
            href="/blog"
            >Blog</a
          >
        </li>
        <li>
          <a
            class="hover:text-[#ecad29] transition-colors"
            href="/contact"
            >Contact</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-[Outfit] font-semibold text-lg uppercase tracking-wide mb-4">
        Newsletter
      </h4>
      <p class="leading-relaxed mb-4">
        Subscribe to receive curated itineraries, custom tour alerts, and photography guides
        directly.
      </p>
      <form class="flex flex-col gap-2">
        <input
          class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-white/5 text-white placeholder-white/40 focus:outline-none focus:border-[#ecad29]/40"
          placeholder="Your email address"
          required
          type="email"
        />
        <button
          class="w-full py-2.5 rounded-lg bg-linear-to-r from-[#ecad29] to-[#ff7a00] hover:from-[#f3b73f] hover:to-[#ff8d23] text-black font-semibold uppercase tracking-wider transition-all shadow-md shadow-[#ecad29]/10"
          type="submit"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 mt-12 pt-6 border-t border-white/5 text-xs text-center text-white/30"
  >
    &copy; {new Date().getFullYear()} Marrakech Express. All rights reserved. Made for Morocco travelers.
  </div>
</footer>
